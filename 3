<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Panel de Control</title>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
  <div class="app-shell">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="brand">
        <span class="b1">⚙️ ADMIN</span>
        <span class="b2">PRO-PAGA</span>
      </div>

      <div class="side-user">
        <div class="name" id="userName">Administrador</div>
        <div class="role">Panel de Control</div>
      </div>

      <nav class="side-menu">
        <button class="side-btn active" onclick="switchAdminTab(this, 'tabDashboard')" data-tab="tabDashboard">
          📊 Dashboard
        </button>
        <button class="side-btn" onclick="switchAdminTab(this, 'tabCargar')" data-tab="tabCargar">
          📥 Cargar CSV
        </button>
        <button class="side-btn" onclick="switchAdminTab(this, 'tabBases')" data-tab="tabBases">
          📚 Bases
        </button>
        <button class="side-btn" onclick="switchAdminTab(this, 'tabUsuarios')" data-tab="tabUsuarios">
          👥 Usuarios
        </button>
        <button class="side-btn" onclick="switchAdminTab(this, 'tabMonitoreo')" data-tab="tabMonitoreo">
          👁️ Monitoreo
        </button>
      </nav>

      <div class="side-footer">
        <button class="btn btn-soft btn-sm" onclick="logout()">🚪 Cerrar sesión</button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main">
      <!-- Tab: Dashboard -->
      <div id="tabDashboard" class="tab-content active">
        <div class="topbar">
          <div class="top-title">
            <h1>Dashboard</h1>
            <p>Resultados y estadísticas generales</p>
          </div>
          <div class="top-actions">
            <button class="mini" onclick="refreshAdmin()">🔄 Actualizar</button>
          </div>
        </div>

        <div class="panel">
          <div class="section-title">
            <h3>Resultados por Período</h3>
          </div>

          <div style="display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap;">
            <input type="date" id="dateInicio" style="flex: 1; min-width: 150px;">
            <input type="date" id="dateFin" style="flex: 1; min-width: 150px;">
            <button class="btn btn-green btn-sm" onclick="cargarReportes()" style="width: auto;">📊 Ver Resultados</button>
          </div>

          <div class="table-wrap">
            <table id="tablaReportes">
              <thead>
                <tr>
                  <th>Agente</th>
                  <th>Total Llamadas</th>
                  <th>Registros</th>
                  <th>Créditos Aceptados</th>
                </tr>
              </thead>
              <tbody id="bodyReportes">
                <tr>
                  <td colspan="4" style="text-align: center;">Selecciona fechas y carga los resultados</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Tab: Cargar CSV -->
      <div id="tabCargar" class="tab-content">
        <div class="topbar">
          <div class="top-title">
            <h1>Cargar Base CSV</h1>
            <p>Importa leads desde un archivo CSV</p>
          </div>
        </div>

        <div class="panel">
          <label class="label">Archivo CSV</label>
          <input type="file" id="csvFile" accept=".csv" style="margin-bottom: 12px;">

          <label class="label">Prioridad</label>
          <select id="csvPrioridad" style="margin-bottom: 12px;">
            <option value="Hot Lead Fase 1">🔥 Hot Lead Fase 1</option>
            <option value="Pendiente" selected>⏳ Pendiente</option>
          </select>

          <label class="label">Asignar a</label>
          <div style="margin-bottom: 12px;">
            <label style="display: flex; align-items: center; gap: 8px;">
              <input type="checkbox" id="csvTodos" checked onchange="toggleTodosCSV(this.checked)">
              Todos los agentes
            </label>
          </div>

          <div id="csvAgentesBox" class="hidden">
            <select id="csvAgentes" multiple style="height: 120px; margin-bottom: 12px;"></select>
          </div>

          <button class="btn btn-green" onclick="subirCSV()" style="width: 100%;">📤 Cargar Base</button>
          <div id="csvMsg" style="margin-top: 12px; color: var(--muted); font-size: 13px;"></div>
        </div>
      </div>

      <!-- Tab: Bases -->
      <div id="tabBases" class="tab-content">
        <div class="topbar">
          <div class="top-title">
            <h1>Bases Cargadas</h1>
            <p>Gestión de bases importadas</p>
          </div>
          <div class="top-actions">
            <button class="mini" onclick="cargarBases()">🔄 Actualizar</button>
          </div>
        </div>

        <div class="panel">
          <div class="table-wrap">
            <table id="tablaBases">
              <thead>
                <tr>
                  <th>Base ID</th>
                  <th>Archivo</th>
                  <th>Fecha</th>
                  <th>Prioridad</th>
                  <th>Registros</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="bodyBases">
                <tr>
                  <td colspan="6" style="text-align: center;">Cargando bases...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Tab: Usuarios -->
      <div id="tabUsuarios" class="tab-content">
        <div class="topbar">
          <div class="top-title">
            <h1>Gestión de Usuarios</h1>
            <p>Crear, editar y eliminar agentes y administradores</p>
          </div>
          <div class="top-actions">
            <button class="mini" onclick="abrirModalNuevoUsuario()">➕ Nuevo Usuario</button>
            <button class="mini" onclick="cargarUsuarios()">🔄 Actualizar</button>
          </div>
        </div>

        <div class="panel">
          <div class="table-wrap">
            <table id="tablaUsuarios">
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Tipo</th>
                  <th>Estado</th>
                  <th>Base</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="bodyUsuarios">
                <tr>
                  <td colspan="5" style="text-align: center;">Cargando usuarios...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Tab: Monitoreo -->
      <div id="tabMonitoreo" class="tab-content">
        <div class="topbar">
          <div class="top-title">
            <h1>Monitoreo en Tiempo Real</h1>
            <p>Estado actual de los agentes</p>
          </div>
          <div class="top-actions">
            <button class="mini" onclick="cargarMonitoreo()">🔄 Actualizar</button>
          </div>
        </div>

        <div id="gridMonitoreo"></div>
      </div>
    </main>
  </div>

  <!-- MODAL: Crear/Editar Usuario -->
  <div id="modalUsuario" class="modal-overlay hidden">
    <div class="modal-box">
      <h3 id="modalTituloUsuario">Nuevo Usuario</h3>
      
      <div style="margin-top: 16px;">
        <label class="label">Nombre del Agente</label>
        <input type="text" id="usuarioNombre" placeholder="Ej: Juan Pérez">
        
        <label class="label">Contraseña</label>
        <input type="password" id="usuarioClave" placeholder="Contraseña segura">
        
        <label class="label">Tipo de Usuario</label>
        <select id="usuarioTipo">
          <option value="Agente">Agente</option>
          <option value="Administrador">Administrador</option>
        </select>
        
        <label class="label">Estado</label>
        <select id="usuarioEstado">
          <option value="Activo">Activo</option>
          <option value="Inactivo">Inactivo</option>
        </select>
        
        <label class="label">Base Asignada</label>
        <select id="usuarioBase">
          <option value="Activo">Activo</option>
          <option value="Inactivo">Inactivo</option>
        </select>
      </div>

      <div class="modal-actions">
        <button class="btn btn-soft btn-sm" onclick="cerrarModalUsuario()">Cancelar</button>
        <button class="btn btn-green btn-sm" id="btnGuardarUsuario" onclick="guardarUsuario()">Guardar</button>
      </div>
    </div>
  </div>

  <script src="js/config.js"></script>
  <script src="js/utils.js"></script>
  <script src="js/auth.js"></script>
  <script src="js/admin.js"></script>
</body>
</html>
