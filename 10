{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "cleanUrls": false,
  "routes": [
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/crm",
      "dest": "/crm.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
